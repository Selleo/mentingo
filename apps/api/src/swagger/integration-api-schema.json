                {
                  "const": "lastName",
                  "type": "string"
                },
                {
                  "const": "email",
                  "type": "string"
                },
                {
                  "const": "createdAt",
                  "type": "string"
                },
                {
                  "const": "groupName",
                  "type": "string"
                },
                {
